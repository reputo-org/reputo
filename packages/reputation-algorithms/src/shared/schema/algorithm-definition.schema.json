{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "AlgorithmDefinition",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "key",
        "name",
        "category",
        "summary",
        "description",
        "version",
        "inputs",
        "outputs",
        "runtime"
    ],
    "properties": {
        "key": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$",
            "minLength": 2
        },
        "name": { "type": "string", "minLength": 1 },
        "kind": {
            "type": "string",
            "enum": ["standalone", "combined"]
        },
        "category": {
            "type": "string",
            "enum": ["Engagement", "Quality", "Activity", "Custom"]
        },
        "summary": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "version": {
            "type": "string",
            "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-[0-9A-Za-z-.]+)?(?:\\+[0-9A-Za-z-.]+)?$"
        },
        "inputs": {
            "type": "array",
            "items": { "$ref": "#/$defs/inputItem" }
        },
        "outputs": {
            "type": "array",
            "minItems": 1,
            "items": { "$ref": "#/$defs/outputItem" }
        },
        "runtime": { "$ref": "#/$defs/runtime" },
        "dependencies": {
            "type": "array",
            "items": { "$ref": "#/$defs/dependencyItem" }
        },
        "validation": {
            "$ref": "#/$defs/validationConfig"
        }
    },
    "$defs": {
        "inputItem": {
            "oneOf": [
                { "$ref": "#/$defs/csvIOItem" },
                { "$ref": "#/$defs/jsonInputItem" },
                { "$ref": "#/$defs/numericParamItem" },
                { "$ref": "#/$defs/stringParamItem" },
                { "$ref": "#/$defs/arrayParamItem" },
                { "$ref": "#/$defs/subAlgorithmInputItem" }
            ]
        },
        "outputItem": {
            "oneOf": [
                { "$ref": "#/$defs/csvIOItem" },
                { "$ref": "#/$defs/jsonIOItem" }
            ]
        },

        "csvIOItem": {
            "type": "object",
            "additionalProperties": false,
            "required": ["key", "type", "csv"],
            "properties": {
                "key": {
                    "type": "string",
                    "pattern": "^[a-z][a-z0-9_]*$",
                    "minLength": 2
                },
                "label": { "type": "string" },
                "description": { "type": "string" },
                "type": { "const": "csv" },
                "csv": { "$ref": "#/$defs/csvMeta" }
            }
        },

        "jsonIOItem": {
            "type": "object",
            "additionalProperties": false,
            "required": ["key", "type"],
            "properties": {
                "key": {
                    "type": "string",
                    "pattern": "^[a-z][a-z0-9_]*$",
                    "minLength": 2
                },
                "label": { "type": "string", "minLength": 1 },
                "description": { "type": "string", "minLength": 1 },
                "type": { "const": "json" }
            }
        },

        "jsonInputItem": {
            "type": "object",
            "additionalProperties": false,
            "required": ["key", "label", "description", "type", "required", "json"],
            "properties": {
                "key": {
                    "type": "string",
                    "pattern": "^[a-z][a-z0-9_]*$",
                    "minLength": 2
                },
                "label": { "type": "string", "minLength": 1 },
                "description": { "type": "string", "minLength": 1 },
                "type": { "const": "json" },
                "required": { "type": "boolean" },
                "json": { "$ref": "#/$defs/jsonMeta" }
            }
        },

        "numericParamItem": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "key",
                "label",
                "description",
                "type",
                "default",
                "required"
            ],
            "properties": {
                "key": {
                    "type": "string",
                    "pattern": "^[a-z][a-z0-9_]*$",
                    "minLength": 2
                },
                "label": { "type": "string", "minLength": 1 },
                "description": { "type": "string", "minLength": 1 },
                "type": {
                    "type": "string",
                    "enum": ["number", "integer"]
                },
                "min": { "type": "number" },
                "max": { "type": "number" },
                "default": { "type": "number" },
                "step": { "type": "number" },
                "uiHint": {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                        "widget": {
                            "type": "string",
                            "enum": ["slider", "number"]
                        },
                        "suffix": { "type": "string" },
                        "presets": {
                            "type": "array",
                            "items": { "type": "number" }
                        }
                    },
                    "required": ["widget"]
                },
                "required": { "type": "boolean" }
            },
            "allOf": [
                {
                    "if": { "required": ["min", "max"] },
                    "then": {
                        "properties": {
                            "min": { "type": "number" },
                            "max": { "type": "number" }
                        }
                    }
                }
            ]
        },

        "stringParamItem": {
            "type": "object",
            "additionalProperties": false,
            "required": ["key", "label", "description", "type", "required"],
            "properties": {
                "key": {
                    "type": "string",
                    "pattern": "^[a-z][a-z0-9_]*$",
                    "minLength": 2
                },
                "label": { "type": "string", "minLength": 1 },
                "description": { "type": "string", "minLength": 1 },
                "type": { "const": "string" },
                "enum": {
                    "type": "array",
                    "items": { "type": "string" },
                    "minItems": 1
                },
                "default": { "type": "string" },
                "required": { "type": "boolean" },
                "uiHint": {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                        "widget": { "const": "select" },
                        "options": {
                            "type": "array",
                            "items": {
                                "type": "object",
                                "required": ["value", "label"],
                                "properties": {
                                    "value": { "type": "string" },
                                    "label": { "type": "string" },
                                    "filterBy": { "type": "string" },
                                    "filters": {
                                        "type": "object",
                                        "additionalProperties": { "type": "string" }
                                    }
                                }
                            }
                        },
                        "dependsOn": {
                            "oneOf": [
                                { "type": "string" },
                                {
                                    "type": "array",
                                    "minItems": 1,
                                    "items": { "type": "string" }
                                }
                            ]
                        }
                    },
                    "required": ["widget"]
                }
            }
        },

        "arrayParamItem": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "key",
                "label",
                "description",
                "type",
                "required",
                "item"
            ],
            "properties": {
                "key": {
                    "type": "string",
                    "pattern": "^[a-z][a-z0-9_]*$",
                    "minLength": 2
                },
                "label": { "type": "string", "minLength": 1 },
                "description": { "type": "string", "minLength": 1 },
                "type": { "const": "array" },
                "minItems": { "type": "integer", "minimum": 0 },
                "required": { "type": "boolean" },
                "uniqueBy": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                        "type": "string",
                        "pattern": "^[a-z][a-z0-9_]*$",
                        "minLength": 2
                    }
                },
                "item": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["type", "properties"],
                    "properties": {
                        "type": { "const": "object" },
                        "properties": {
                            "type": "array",
                            "minItems": 1,
                            "items": { "$ref": "#/$defs/objectPropertyParam" }
                        }
                    }
                },
                "uiHint": {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                        "widget": {
                            "type": "string",
                            "enum": ["repeater", "resource_selector"]
                        },
                        "addButtonLabel": { "type": "string" },
                        "dependsOn": {
                            "oneOf": [
                                { "type": "string" },
                                {
                                    "type": "array",
                                    "minItems": 1,
                                    "items": { "type": "string" }
                                }
                            ]
                        },
                        "presets": {
                            "type": "array",
                            "items": {
                                "type": "object",
                                "required": ["label", "value"],
                                "additionalProperties": false,
                                "properties": {
                                    "label": {
                                        "type": "string",
                                        "minLength": 1
                                    },
                                    "value": {
                                        "type": "array",
                                        "items": {}
                                    }
                                }
                            }
                        },
                        "resourceCatalog": { "$ref": "#/$defs/resourceCatalog" }
                    },
                    "required": ["widget"],
                    "allOf": [
                        {
                            "if": {
                                "properties": {
                                    "widget": { "const": "resource_selector" }
                                }
                            },
                            "then": {
                                "required": ["resourceCatalog"]
                            }
                        }
                    ]
                }
            }
        },

        "subAlgorithmInputItem": {
            "type": "object",
            "additionalProperties": false,
            "required": ["key", "label", "description", "type", "required"],
            "properties": {
                "key": {
                    "type": "string",
                    "pattern": "^[a-z][a-z0-9_]*$",
                    "minLength": 2
                },
                "label": { "type": "string", "minLength": 1 },
                "description": { "type": "string", "minLength": 1 },
                "type": { "const": "sub_algorithm" },
                "required": { "type": "boolean" },
                "minItems": { "type": "integer", "minimum": 0 },
                "maxItems": { "type": "integer", "minimum": 0 },
                "sharedInputKeys": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                        "type": "string",
                        "pattern": "^[a-z][a-z0-9_]*$",
                        "minLength": 2
                    }
                },
                "uiHint": {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                        "widget": { "const": "sub_algorithm_composer" },
                        "addButtonLabel": { "type": "string", "minLength": 1 }
                    },
                    "required": ["widget"]
                }
            }
        },

        "objectPropertyParam": {
            "oneOf": [
                { "$ref": "#/$defs/scalarObjectPropertyParam" },
                { "$ref": "#/$defs/arrayObjectPropertyParam" }
            ]
        },

        "scalarObjectPropertyParam": {
            "type": "object",
            "additionalProperties": false,
            "required": ["key", "label", "description", "type", "required"],
            "properties": {
                "key": {
                    "type": "string",
                    "pattern": "^[a-z][a-z0-9_]*$",
                    "minLength": 2
                },
                "label": { "type": "string", "minLength": 1 },
                "description": { "type": "string", "minLength": 1 },
                "type": {
                    "type": "string",
                    "enum": ["string", "integer", "number"]
                },
                "enum": {
                    "type": "array",
                    "items": { "type": "string" },
                    "minItems": 1
                },
                "default": {},
                "required": { "type": "boolean" },
                "uiHint": {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                        "widget": { "const": "select" },
                        "options": {
                            "type": "array",
                            "items": {
                                "type": "object",
                                "required": ["value", "label"],
                                "properties": {
                                    "value": { "type": "string" },
                                    "label": { "type": "string" },
                                    "filterBy": { "type": "string" },
                                    "filters": {
                                        "type": "object",
                                        "additionalProperties": { "type": "string" }
                                    }
                                }
                            }
                        },
                        "dependsOn": {
                            "oneOf": [
                                { "type": "string" },
                                {
                                    "type": "array",
                                    "minItems": 1,
                                    "items": { "type": "string" }
                                }
                            ]
                        }
                    },
                    "required": ["widget"]
                }
            }
        },

        "arrayObjectPropertyParam": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "key",
                "label",
                "description",
                "type",
                "required",
                "item"
            ],
            "properties": {
                "key": {
                    "type": "string",
                    "pattern": "^[a-z][a-z0-9_]*$",
                    "minLength": 2
                },
                "label": { "type": "string", "minLength": 1 },
                "description": { "type": "string", "minLength": 1 },
                "type": { "const": "array" },
                "minItems": { "type": "integer", "minimum": 0 },
                "required": { "type": "boolean" },
                "uniqueBy": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                        "type": "string",
                        "pattern": "^[a-z][a-z0-9_]*$",
                        "minLength": 2
                    }
                },
                "item": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["type", "properties"],
                    "properties": {
                        "type": { "const": "object" },
                        "properties": {
                            "type": "array",
                            "minItems": 1,
                            "items": { "$ref": "#/$defs/objectPropertyParam" }
                        }
                    }
                },
                "uiHint": {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                        "widget": { "const": "repeater" },
                        "addButtonLabel": { "type": "string" },
                        "dependsOn": {
                            "oneOf": [
                                { "type": "string" },
                                {
                                    "type": "array",
                                    "minItems": 1,
                                    "items": { "type": "string" }
                                }
                            ]
                        }
                    },
                    "required": ["widget"]
                }
            }
        },

        "resourceCatalog": {
            "type": "object",
            "additionalProperties": false,
            "required": ["chains"],
            "properties": {
                "chains": {
                    "type": "array",
                    "minItems": 1,
                    "items": { "$ref": "#/$defs/resourceCatalogChain" }
                }
            }
        },

        "resourceCatalogChain": {
            "type": "object",
            "additionalProperties": false,
            "required": ["key", "label", "resources"],
            "properties": {
                "key": {
                    "type": "string",
                    "pattern": "^[a-z][a-z0-9_]*$",
                    "minLength": 2
                },
                "label": { "type": "string", "minLength": 1 },
                "resources": {
                    "type": "array",
                    "minItems": 1,
                    "items": { "$ref": "#/$defs/resourceCatalogResource" }
                }
            }
        },

        "resourceCatalogResource": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "key",
                "label",
                "kind",
                "identifier",
                "tokenIdentifier",
                "tokenKey"
            ],
            "properties": {
                "key": {
                    "type": "string",
                    "pattern": "^[a-z][a-z0-9_]*$",
                    "minLength": 2
                },
                "label": { "type": "string", "minLength": 1 },
                "description": { "type": "string", "minLength": 1 },
                "kind": {
                    "type": "string",
                    "enum": ["token", "contract"]
                },
                "identifier": { "type": "string", "minLength": 1 },
                "tokenIdentifier": { "type": "string", "minLength": 1 },
                "tokenKey": {
                    "type": "string",
                    "pattern": "^[a-z][a-z0-9_]*$",
                    "minLength": 2
                },
                "parentResourceKey": {
                    "type": "string",
                    "pattern": "^[a-z][a-z0-9_]*$",
                    "minLength": 2
                },
                "explorerUrl": {
                    "type": "string",
                    "format": "uri"
                },
                "explorerLabel": { "type": "string", "minLength": 1 },
                "iconUrl": {
                    "type": "string",
                    "format": "uri"
                }
            }
        },

        "validationConfig": {
            "type": "object",
            "additionalProperties": false,
            "required": ["rules"],
            "properties": {
                "rules": {
                    "type": "array",
                    "minItems": 1,
                    "items": { "$ref": "#/$defs/validationRule" }
                }
            }
        },

        "validationRule": {
            "oneOf": [{ "$ref": "#/$defs/jsonChainCoverageRule" }]
        },

        "jsonChainCoverageRule": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "kind",
                "walletInputKey",
                "selectorInputKey",
                "selectorChainField"
            ],
            "properties": {
                "kind": { "const": "json_chain_coverage" },
                "walletInputKey": {
                    "type": "string",
                    "pattern": "^[a-z][a-z0-9_]*$",
                    "minLength": 2
                },
                "selectorInputKey": {
                    "type": "string",
                    "pattern": "^[a-z][a-z0-9_]*$",
                    "minLength": 2
                },
                "selectorChainField": {
                    "type": "string",
                    "pattern": "^[a-z][a-z0-9_]*$",
                    "minLength": 2
                }
            }
        },

        "csvMeta": {
            "type": "object",
            "additionalProperties": false,
            "required": ["columns"],
            "properties": {
                "hasHeader": { "type": "boolean", "default": true },
                "delimiter": {
                    "type": "string",
                    "minLength": 1,
                    "default": ","
                },
                "maxRows": { "type": "integer", "minimum": 1 },
                "maxBytes": { "type": "integer", "minimum": 1 },
                "columns": {
                    "type": "array",
                    "minItems": 1,
                    "items": { "$ref": "#/$defs/csvColumn" }
                }
            }
        },

        "jsonMeta": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "maxBytes": { "type": "integer", "minimum": 1 },
                "schema": { "type": "string", "minLength": 1 },
                "rootKey": {
                    "type": "string",
                    "pattern": "^[a-z][a-z0-9_]*$",
                    "minLength": 1
                },
                "allowedChains": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                        "type": "string",
                        "enum": ["ethereum", "cardano"]
                    }
                }
            }
        },

        "csvColumn": {
            "type": "object",
            "additionalProperties": false,
            "required": ["key", "type"],
            "properties": {
                "key": {
                    "type": "string",
                    "pattern": "^[a-z][a-z0-9_]*$",
                    "minLength": 2
                },
                "type": {
                    "type": "string",
                    "enum": ["string", "integer", "number", "date", "enum"]
                },
                "required": { "type": "boolean", "default": true },
                "enum": {
                    "type": "array",
                    "items": { "type": ["string", "number"] },
                    "minItems": 1
                },
                "aliases": {
                    "type": "array",
                    "items": { "type": "string", "minLength": 1 }
                },
                "description": { "type": "string" }
            },
            "allOf": [
                {
                    "if": {
                        "properties": { "type": { "const": "enum" } },
                        "required": ["type"]
                    },
                    "then": { "required": ["enum"] }
                }
            ]
        },

        "runtime": {
            "type": "string",
            "enum": ["typescript", "python"]
        },

        "dependencyItem": {
            "type": "object",
            "additionalProperties": false,
            "required": ["key"],
            "properties": {
                "key": {
                    "type": "string",
                    "enum": ["onchain-data", "deepfunding-portal-api", "deep-id"]
                }
            }
        }
    }
}
