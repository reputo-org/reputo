{
    "key": "token_value_over_time",
    "name": "Token Value Over Time",
    "kind": "standalone",
    "category": "Activity",
    "summary": "Scores each SubID by wallet value kept over time, with more weight for longer-held FET.",
    "description": "### What it does\nScores each user from the FET still held in their linked wallets.\n\n### How it works\n- Users and their wallets come from DeepID.\n- Each incoming transfer becomes a separate lot.\n- A lot gains value as it gets older and reaches full value at the maturation period.\n- When tokens leave a wallet, the oldest lots are used first.\n- Wallet scores are added together for each user.\n\n### Resource selection\nChoose the FET token or staking resources to include in scoring.\n\n### Data source\nUses indexed token transfer data for each user's wallets.\n\n### Output\n- CSV file with `did` and `token_value`.\n- JSON file with score details for each SubID, wallet, and lot.",
    "version": "1.0.0",
    "inputs": [
        {
            "key": "maturation_threshold_days",
            "label": "Maturation Period (Days)",
            "description": "Number of days a token lot must be held to reach full value.",
            "type": "integer",
            "min": 1,
            "max": 3650,
            "default": 90,
            "step": 1,
            "required": true,
            "uiHint": {
                "widget": "number",
                "suffix": "days",
                "presets": [7, 30, 90, 180, 365]
            }
        },
        {
            "key": "selected_resources",
            "label": "Token Resources to Score",
            "description": "Choose the FET token or staking resources to include.",
            "type": "array",
            "minItems": 1,
            "required": true,
            "uniqueBy": ["chain", "resource_key"],
            "uiHint": {
                "widget": "resource_selector",
                "presets": [
                    {
                        "label": "FET (all chains)",
                        "value": [
                            {
                                "chain": "ethereum",
