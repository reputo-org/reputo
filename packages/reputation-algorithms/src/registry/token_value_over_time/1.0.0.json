    "dependencies": [{ "key": "onchain-data" }, { "key": "deep-id" }],
    "outputs": [
        {
            "key": "token_value_over_time",
            "label": "Token Value Over Time (CSV)",
            "description": "CSV file with one row per SubID and the final token value score.",
            "type": "csv",
            "csv": {
                "hasHeader": true,
                "delimiter": ",",
                "columns": [
                    {
                        "key": "did",
                        "type": "string",
                        "description": "SubID from the uploaded JSON input."
                    },
                    {
                        "key": "token_value",
                        "type": "number",
                        "description": "Final token value score for the SubID."
                    }
                ]
            }
        },
        {
            "key": "token_value_over_time_details",
            "label": "Token Value Over Time Details (JSON)",
            "description": "JSON file with score details for each SubID, wallet, and lot.",
            "type": "json"
        }
    ],
    "runtime": "typescript"
}
