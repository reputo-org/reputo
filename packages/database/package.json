{
    "name": "@reputo/database",
    "version": "0.0.0",
    "description": "Mongoose-based database layer for the Reputo ecosystem.",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "private": true,
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        }
    },
    "type": "module",
    "module": "dist/index.js",
    "scripts": {
        "check": "pnpm exec biome check",
        "lint": "pnpm exec biome lint",
        "format": "pnpm exec biome format --write",
        "test": "vitest run",
        "test:watch": "vitest --watch",
        "test:cov": "vitest --coverage",
        "typecheck": "tsc --noEmit",
        "dev": "tsc --watch --preserveWatchOutput",
        "build": "tsc",
        "docs": "typedoc",
        "clean": "rm -rf coverage dist docs node_modules tsconfig.tsbuildinfo"
    },
    "dependencies": {
        "mongoose": "catalog:"
    },
    "devDependencies": {
        "@types/node": "catalog:",
        "mongodb-memory-server": "^10.2.3",
        "tsx": "catalog:",
        "typedoc": "catalog:",
        "typedoc-plugin-markdown": "catalog:",
        "typescript": "catalog:",
        "vitest": "catalog:"
    },
    "keywords": [
        "typescript",
        "database",
        "mongoose"
    ],
    "files": [
        "dist",
        "!dist/**/*.test.*"
    ],
    "author": {
        "name": "Behzad Rabiei",
        "url": "https://github.com/Behzad-rabiei"
    },
    "license": "GPL-3.0",
    "packageManager": "pnpm@10.30.3"
}
