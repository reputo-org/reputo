{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "strict": true,
    "noEmit": true,
    "types": ["vitest/globals", "node"]
  },
  "include": ["vitest.base.ts", "vitest.config.ts", "packages/**/*.{ts,tsx}", "apps/**/*.{ts,tsx}"],
  "exclude": ["**/dist/**", "**/node_modules/**", "**/.next/**"]
}
