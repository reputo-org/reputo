{
  "branches": ["main"],
  "plugins": [
    ["semantic-release-commits-lint", { "commitlintFile": "./commitlint.config.mjs" }],
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    "@semantic-release/github",
    [
      "@semantic-release/exec",
      {
        "successCmd": "echo \"version=${nextRelease.gitTag}\" >> $GITHUB_OUTPUT"
      }
    ]
  ]
}
