# Workflows Service Environment Configuration Example
# Copy this file to workflows.env and update with your actual values
# This file is used by orchestrator-worker, onchain-data-worker, and typescript-worker services

# Node Environment
NODE_ENV=development

# Logging
LOG_LEVEL=info

# Temporal Configuration
TEMPORAL_ADDRESS=temporal:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_ORCHESTRATOR_TASK_QUEUE=orchestrator-worker
TEMPORAL_ALGORITHM_TYPESCRIPT_TASK_QUEUE=algorithm-typescript-worker
TEMPORAL_ALGORITHM_PYTHON_TASK_QUEUE=algorithm-python-worker
TEMPORAL_ONCHAIN_DATA_TASK_QUEUE=onchain-data-worker

# AWS Configuration
AWS_REGION=us-east-1
# AWS credentials (only used in non-production environments)
# In production, IAM roles are used instead
# AWS_ACCESS_KEY_ID=your-access-key-id
# AWS_SECRET_ACCESS_KEY=your-secret-access-key

# Storage Configuration
STORAGE_BUCKET=reputo-snapshots
STORAGE_PRESIGN_PUT_TTL=120
STORAGE_PRESIGN_GET_TTL=300
STORAGE_MAX_SIZE_BYTES=52428800
# Include application/x-sqlite3 if running algorithms that use DeepFunding (contribution_score, proposal_engagement)
STORAGE_CONTENT_TYPE_ALLOWLIST=text/csv,application/json,application/x-sqlite3

# DeepFunding Portal API Configuration 
DEEPFUNDING_API_BASE_URL=https://deep-projects.ai/wp-json/deepfunding/v1
DEEPFUNDING_API_KEY=
# DEEPFUNDING_API_REQUEST_TIMEOUT_MS=10000
# DEEPFUNDING_API_CONCURRENCY=10
# DEEPFUNDING_API_DEFAULT_PAGE_LIMIT=100
# DEEPFUNDING_API_RETRY_MAX_ATTEMPTS=3
# DEEPFUNDING_API_RETRY_BASE_DELAY_MS=1000
# DEEPFUNDING_API_RETRY_MAX_DELAY_MS=10000



# Alchemy and Blockfrost Configuration
ALCHEMY_API_KEY=random-api-key
BLOCKFROST_API_KEY=random-blockfrost-api-key

# Onchain Data PostgreSQL Configuration
ONCHAIN_DATA_POSTGRES_HOST=onchain-data-postgresql
# Use the container port on the Docker network; 5433 is only the host-published port.
ONCHAIN_DATA_POSTGRES_PORT=5432
ONCHAIN_DATA_POSTGRES_USER=reputo_onchain
ONCHAIN_DATA_POSTGRES_PASSWORD=reputo_onchain
ONCHAIN_DATA_POSTGRES_DB_NAME=reputo_onchain
