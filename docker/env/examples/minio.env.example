# MinIO Configuration (local S3 stand-in for dev/preview).
# Copy this file to docker/env/minio.env. Defaults are safe for local use only.

MINIO_ROOT_USER=reputo
MINIO_ROOT_PASSWORD=reputo-dev-secret

# Comma-separated bucket list created automatically by the minio-init sidecar.
MINIO_BUCKETS=reputo-snapshots,reputo-pullpreview
