# Reputo self-host production environment (Komodo-free path).
#
# Copy this file to docker/env/prod.env, fill every value, then run:
#
#   make selfhost-config   # validate the compose merge
#   make selfhost-pull
#   make selfhost-up
#
# This file is the single source of truth for the bundled
# infra.yml + observability.yml + apps.yml stack when deployed without Komodo.
# It mirrors the variables Komodo writes into the .komodo-reputo-*.env files
# on its target hosts. See docs/handoff/README.md.

# ─── Image channel ──────────────────────────────────────────────────────────
# `staging` follows the moving staging tag; `production` follows the moving
# production tag. For pinned deploys, use `sha-<commit>` or `prod-<commit>`.
IMAGE_TAG=production
NODE_ENV=production
LOG_LEVEL=info

# ─── DNS / Edge ─────────────────────────────────────────────────────────────
TRAEFIK_DOMAIN=traefik.example.com
UI_DOMAIN=app.example.com
API_DOMAIN=api.example.com
TEMPORAL_UI_DOMAIN=temporal.example.com
GRAFANA_DOMAIN=grafana.example.com
ALLOWED_ORIGINS=https://app.example.com
OBSERVABILITY_ENV=production

# Cloudflare DNS-01 ACME (Traefik). Use a scoped API token, not Global API Key.
CF_DNS_API_TOKEN=replace-with-cloudflare-api-token

# htpasswd-style auth for the Traefik dashboard and Grafana.
# Generate with `htpasswd -nbB user password`. Replace every `$` with `$$`.
TRAEFIK_AUTH=admin:$$apr1$$REPLACE$$REPLACE
GRAFANA_AUTH=admin:$$apr1$$REPLACE$$REPLACE

# ─── Auth (DeepID OAuth) ────────────────────────────────────────────────────
AUTH_MODE=oauth
# OWNER_EMAIL seeds the single owner allowlist row. The API refuses to start
# if this is missing or conflicts with an existing active owner.
OWNER_EMAIL=owner@example.com
APP_PUBLIC_URL=https://app.example.com
DEEP_ID_ISSUER_URL=https://identity.deep-id.ai
DEEP_ID_CLIENT_ID=replace-with-deep-id-client-id
DEEP_ID_CLIENT_SECRET=replace-with-deep-id-client-secret
DEEP_ID_AUTH_REDIRECT_URI=https://api.example.com/api/v1/auth/deep-id/callback
DEEP_ID_AUTH_SCOPES=openid profile email offline_access
DEEP_ID_CONSENT_REDIRECT_URI=https://api.example.com/api/v1/oauth/consent/deep-id/callback
DEEP_ID_CONSENT_GRANT_TTL_SECONDS=600
VOTING_PORTAL_RETURN_URL=https://app.example.com/voting
DEEP_ID_VOTING_PORTAL_SCOPES=api wallets

# Session cookie
AUTH_COOKIE_NAME=reputo_auth_session
AUTH_COOKIE_DOMAIN=example.com
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAME_SITE=lax
AUTH_SESSION_TTL_SECONDS=2592000
AUTH_REFRESH_LEEWAY_SECONDS=60
# 32-byte hex (64 chars). Generate: openssl rand -hex 32
AUTH_TOKEN_ENCRYPTION_KEY=replace-with-a-long-random-secret-at-least-32-characters

# ─── Application MongoDB ────────────────────────────────────────────────────
MONGODB_DB_NAME=reputo
MONGODB_USER=reputo_app
MONGODB_PASSWORD=replace-with-strong-password

# Mongo container root credentials.
# IMPORTANT: must literally match MONGODB_USER / MONGODB_PASSWORD above.
# Docker Compose env files do not interpolate variables, so duplicate the value.
MONGO_INITDB_ROOT_USERNAME=reputo_app
MONGO_INITDB_ROOT_PASSWORD=replace-with-strong-password

# ─── Storage ────────────────────────────────────────────────────────────────
# Credentials are resolved by the SDK from the host's IAM role (or
# AWS_ACCESS_KEY_ID/SECRET set in the host shell). They are intentionally
# not in this file.
AWS_REGION=us-east-1
# Leave S3_ENDPOINT blank for real AWS S3; set to a MinIO/LocalStack URL for
# self-hosted S3-compatible storage.
S3_ENDPOINT=
S3_FORCE_PATH_STYLE=false
STORAGE_BUCKET=reputo-prod
STORAGE_PRESIGN_PUT_TTL=120
STORAGE_PRESIGN_GET_TTL=300
STORAGE_MAX_SIZE_BYTES=52428800
API_STORAGE_CONTENT_TYPE_ALLOWLIST=text/csv,text/plain,application/json
WORKFLOWS_STORAGE_CONTENT_TYPE_ALLOWLIST=text/csv,application/json,application/x-sqlite3

# ─── Temporal ───────────────────────────────────────────────────────────────
TEMPORAL_ADDRESS=temporal:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_ORCHESTRATOR_TASK_QUEUE=orchestrator-worker
TEMPORAL_ALGORITHM_TYPESCRIPT_TASK_QUEUE=algorithm-typescript-worker
TEMPORAL_ALGORITHM_PYTHON_TASK_QUEUE=algorithm-python-worker
TEMPORAL_ONCHAIN_DATA_TASK_QUEUE=onchain-data-worker

TEMPORAL_POSTGRES_USER=temporal
TEMPORAL_POSTGRES_PASSWORD=replace-with-strong-password

# ─── Onchain data Postgres ──────────────────────────────────────────────────
ONCHAIN_DATA_POSTGRES_DB_NAME=reputo_onchain
ONCHAIN_DATA_POSTGRES_USER=reputo_onchain
ONCHAIN_DATA_POSTGRES_PASSWORD=replace-with-strong-password

# ─── DeepFunding / chain APIs ───────────────────────────────────────────────
DEEPFUNDING_API_BASE_URL=https://deep-projects.ai/wp-json/deepfunding/v1
DEEPFUNDING_API_KEY=replace-with-deepfunding-api-key
DEEPFUNDING_API_REQUEST_TIMEOUT_MS=45000
DEEPFUNDING_API_CONCURRENCY=4
DEEPFUNDING_API_DEFAULT_PAGE_LIMIT=500
DEEPFUNDING_API_RETRY_MAX_ATTEMPTS=7
DEEPFUNDING_API_RETRY_BASE_DELAY_MS=500
DEEPFUNDING_API_RETRY_MAX_DELAY_MS=20000
ALCHEMY_API_KEY=replace-with-alchemy-api-key
BLOCKFROST_API_KEY=replace-with-blockfrost-api-key

# ─── Grafana admin user (initial; rotate after first login) ─────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-with-strong-password
