# API Service Environment Configuration Example
# Copy this file to api.env and update with your actual values

# Application Configuration
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# MongoDB Configuration
MONGODB_HOST=mongodb
MONGODB_PORT=27017
MONGODB_DB_NAME=reputo_dev
# Auth optional for local dev - uncomment if using auth
# MONGODB_USER=admin
# MONGODB_PASSWORD=password

# AWS Configuration
AWS_REGION=us-east-1
# AWS credentials (only used in non-production environments)
# In production, IAM roles are used instead
# AWS_ACCESS_KEY_ID=your-access-key-id
# AWS_SECRET_ACCESS_KEY=your-secret-access-key

# Storage Configuration
STORAGE_BUCKET=reputo-snapshots
STORAGE_PRESIGN_PUT_TTL=120
STORAGE_PRESIGN_GET_TTL=300
STORAGE_MAX_SIZE_BYTES=52428800
STORAGE_CONTENT_TYPE_ALLOWLIST=text/csv,application/json

# Temporal Configuration
TEMPORAL_ADDRESS=temporal:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_ORCHESTRATOR_TASK_QUEUE=orchestrator-worker

# Deep ID Configuration
AUTH_MODE=oauth
# Required when AUTH_MODE=oauth. Seeds the single owner allowlist row;
# startup fails if it conflicts with an existing active owner.
OWNER_EMAIL=owner@example.com
APP_PUBLIC_URL=http://localhost:5173
DEEP_ID_ISSUER_URL=https://identity.deep-id.ai
DEEP_ID_CLIENT_ID=your-deep-id-client-id
DEEP_ID_CLIENT_SECRET=your-deep-id-client-secret
DEEP_ID_AUTH_REDIRECT_URI=http://localhost:3000/api/v1/auth/deep-id/callback
DEEP_ID_AUTH_SCOPES=openid profile email offline_access

# Deep ID Consent Configuration
DEEP_ID_CONSENT_REDIRECT_URI=http://localhost:3000/api/v1/oauth/consent/deep-id/callback
DEEP_ID_CONSENT_GRANT_TTL_SECONDS=600
VOTING_PORTAL_RETURN_URL=http://localhost:3001/voting
DEEP_ID_VOTING_PORTAL_SCOPES=api wallets

# Cookie Configuration
AUTH_COOKIE_NAME=reputo_auth_session
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=lax
AUTH_SESSION_TTL_SECONDS=2592000
AUTH_REFRESH_LEEWAY_SECONDS=60
AUTH_TOKEN_ENCRYPTION_KEY=replace-with-a-long-random-secret-at-least-32-characters
