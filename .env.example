# Reputo local development environment
#
# Copy this file to `.env` at the repo root and fill in the placeholders.
# This single file replaces the per-app `apps/<app>/envs.example` and the
# per-service `docker/env/examples/*.env.example` files.
#
# Source of truth for which vars exist and how they're validated:
#   apps/api/src/config/env.ts
#   apps/ui/src/lib/env.ts
#   apps/workflows/src/config/env.ts
#
# Vars marked OPTIONAL have a Zod default — list them here only if you need to
# override the default locally. Vars marked REQUIRED have no default; the app
# refuses to start without them. SECRET values must never be committed.
#
# Staging/production values live in Komodo Variables, not here.

# =============================================================================
# Runtime
# =============================================================================

# REQUIRED (api + workflows): one of production | development | test
NODE_ENV=development

# OPTIONAL (api + workflows): Pino log level. Default: info
# LOG_LEVEL=info

# =============================================================================
# API HTTP server (apps/api)
# =============================================================================

# OPTIONAL: HTTP port. Default: 3000
# PORT=3000

# OPTIONAL: Public URL the API advertises after login. Default: none (required at runtime)
APP_PUBLIC_URL=http://localhost:5173

# =============================================================================
# Authentication (apps/api)
# =============================================================================

# OPTIONAL: oauth | mock. Default: oauth. mock is rejected in production.
# AUTH_MODE=oauth

# REQUIRED when AUTH_MODE=oauth: email seeded as the single owner allowlist entry.
OWNER_EMAIL=owner@example.com

# OPTIONAL: OAuth provider the owner is seeded against. Default: deep-id
# OWNER_PROVIDER=deep-id

# REQUIRED: Deep ID OIDC issuer + client.
DEEP_ID_ISSUER_URL=https://identity.deep-id.ai
DEEP_ID_CLIENT_ID=
DEEP_ID_CLIENT_SECRET=                           # SECRET
DEEP_ID_AUTH_REDIRECT_URI=http://localhost:3000/api/v1/auth/deep-id/callback
DEEP_ID_AUTH_SCOPES=openid profile email offline_access

# REQUIRED: Deep ID consent flow + voting portal.
DEEP_ID_CONSENT_REDIRECT_URI=http://localhost:3000/api/v1/oauth/consent/deep-id/callback
DEEP_ID_CONSENT_GRANT_TTL_SECONDS=600
VOTING_PORTAL_RETURN_URL=http://localhost:3001/voting
DEEP_ID_VOTING_PORTAL_SCOPES=api wallets

# OPTIONAL: Default 300000 (5 min).
# DEEP_ID_CONSENT_CLEANUP_INTERVAL_MS=300000

# OPTIONAL: Cookie shape. Defaults: name=reputo_auth_session, secure=false,
# same_site=lax, ttl=2592000, refresh_leeway=60, cleanup_interval=3600000
# AUTH_COOKIE_NAME=reputo_auth_session
# AUTH_COOKIE_DOMAIN=
# AUTH_COOKIE_SECURE=false
# AUTH_COOKIE_SAME_SITE=lax
# AUTH_SESSION_TTL_SECONDS=2592000
# AUTH_REFRESH_LEEWAY_SECONDS=60
# AUTH_SESSION_CLEANUP_INTERVAL_MS=3600000

# REQUIRED: 32+ chars. Generate with `openssl rand -hex 32`. SECRET.
AUTH_TOKEN_ENCRYPTION_KEY=

# =============================================================================
# Application database (apps/api)
# =============================================================================

# REQUIRED: postgres:// URL. For dev, points at docker/compose/dev.yml's
# `postgres` service (host port 5434). Credentials in the URL must match what
# docker/compose/dev.yml hardcodes for the postgres container.
DATABASE_URL=postgresql://reputo_app:reputo_app@localhost:5434/reputo_app

# =============================================================================
# Onchain-data database (apps/workflows)
# =============================================================================

# REQUIRED: postgres:// URL for the onchain-data worker. For dev, points at
# docker/compose/dev.yml's `onchain-data-postgresql` service (host port 5433).
ONCHAIN_DATABASE_URL=postgresql://reputo_onchain:reputo_onchain@localhost:5433/reputo_onchain

# =============================================================================
# AWS / object storage (apps/api + apps/workflows)
# =============================================================================

# REQUIRED.
AWS_REGION=eu-north-1

# OPTIONAL: explicit AWS credentials. Must be set together OR both omitted.
# Omit in production (IAM role credentials). SECRET if set.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# REQUIRED: S3 bucket for algorithm inputs/outputs.
STORAGE_BUCKET=reputo-snapshots

# OPTIONAL: presigned URL TTLs (seconds) and upload limits.
# Defaults: PUT_TTL=120, GET_TTL=300, MAX_SIZE_BYTES=52428800 (50 MiB),
# ALLOWLIST="text/csv,text/plain,application/json".
# STORAGE_PRESIGN_PUT_TTL=120
# STORAGE_PRESIGN_GET_TTL=300
# STORAGE_MAX_SIZE_BYTES=52428800
# STORAGE_CONTENT_TYPE_ALLOWLIST=text/csv,text/plain,application/json

# =============================================================================
# Temporal (apps/api + apps/workflows)
# =============================================================================

# REQUIRED: Temporal server host:port. Use `temporal:7233` inside docker compose,
# `localhost:7233` from a host shell during `pnpm dev`.
TEMPORAL_ADDRESS=localhost:7233

# OPTIONAL: namespace + task-queue names. Defaults wired to the docker dev stack.
# TEMPORAL_NAMESPACE=default
# TEMPORAL_ORCHESTRATOR_TASK_QUEUE=orchestrator-worker
# TEMPORAL_ALGORITHM_TYPESCRIPT_TASK_QUEUE=algorithm-typescript-worker
# TEMPORAL_ALGORITHM_PYTHON_TASK_QUEUE=algorithm-python-worker
# TEMPORAL_ONCHAIN_DATA_TASK_QUEUE=onchain-data-worker
# TEMPORAL_API_SNAPSHOT_ACTIVITIES_TASK_QUEUE=api-snapshot-activities

# =============================================================================
# DeepFunding Portal API (apps/workflows)
# =============================================================================

# REQUIRED.
DEEPFUNDING_API_BASE_URL=https://deep-projects.ai/wp-json/deepfunding/v1
DEEPFUNDING_API_KEY=                              # SECRET

# OPTIONAL tuning. Defaults: timeout=45000, concurrency=4, page_limit=500,
# retry_max=7, retry_base_ms=500, retry_max_ms=20000.
# DEEPFUNDING_API_REQUEST_TIMEOUT_MS=45000
# DEEPFUNDING_API_CONCURRENCY=4
# DEEPFUNDING_API_DEFAULT_PAGE_LIMIT=500
# DEEPFUNDING_API_RETRY_MAX_ATTEMPTS=7
# DEEPFUNDING_API_RETRY_BASE_DELAY_MS=500
# DEEPFUNDING_API_RETRY_MAX_DELAY_MS=20000

# =============================================================================
# Onchain data providers (apps/workflows)
# =============================================================================

# REQUIRED — both SECRETS.
ALCHEMY_API_KEY=
BLOCKFROST_API_KEY=

# =============================================================================
# UI (apps/ui)
# =============================================================================

# OPTIONAL: cookie name; must match the API's AUTH_COOKIE_NAME if either is set.
# Default: reputo_auth_session
# AUTH_COOKIE_NAME=reputo_auth_session

# OPTIONAL: dev-only Next.js rewrite target. Leave unset in Docker (Traefik
# routes /api). Default: unset.
API_PROXY_TARGET=http://localhost:3000
