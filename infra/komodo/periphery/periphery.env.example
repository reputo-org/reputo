# Copy this file to periphery.env on each staging/production host.
# Do not commit periphery.env. Store every CHANGE_ME value in the password manager.

# Image tag. Keep this aligned with Komodo Core unless intentionally testing.
COMPOSE_KOMODO_IMAGE_TAG=2

# Runtime
TZ=Europe/Vienna
PERIPHERY_CONTAINER_NAME=komodo-periphery
PERIPHERY_DOCKER_NETWORK=reputo
PERIPHERY_ROOT_DIRECTORY=/etc/komodo

# Inbound Core -> Periphery connection.
# The published address should be a private/VPN interface reachable by Komodo Core,
# not 0.0.0.0 or the host's public internet address.
PERIPHERY_PUBLISH_IP=CHANGE_ME_PRIVATE_OR_VPN_HOST_IP
PERIPHERY_BIND_IP=0.0.0.0
PERIPHERY_PORT=8120
PERIPHERY_SERVER_ENABLED=true
PERIPHERY_SSL_ENABLED=false

# Restrict Periphery API callers to Komodo Core's IP or the VPN subnet.
# Examples: 203.0.113.10/32, 10.8.0.0/24
PERIPHERY_ALLOWED_IPS=CHANGE_ME_CORE_IP_OR_VPN_CIDR

# Legacy passkey auth. Use the same value as KOMODO_PASSKEY on Core.
KOMODO_PASSKEY=CHANGE_ME_FROM_PASSWORD_MANAGER

# Post-cutover security posture.
# These disable browser shell and container exec/attach access through Periphery.
PERIPHERY_DISABLE_TERMINALS=true
PERIPHERY_DISABLE_CONTAINER_TERMINALS=true

# Monitoring
PERIPHERY_STATS_POLLING_RATE=5-sec
PERIPHERY_CONTAINER_STATS_POLLING_RATE=30-sec
PERIPHERY_INCLUDE_DISK_MOUNTS=/etc/hostname
PERIPHERY_LOGGING_LEVEL=info
PERIPHERY_LOGGING_STDIO=standard
PERIPHERY_LOGGING_PRETTY=false
PERIPHERY_PRETTY_STARTUP_CONFIG=false
