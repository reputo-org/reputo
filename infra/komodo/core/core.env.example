# Copy this file to core.env on the dedicated Komodo host.
# Do not commit core.env. Store every CHANGE_ME value in the password manager.

# Image tags
COMPOSE_KOMODO_IMAGE_TAG=2
FERRETDB_POSTGRES_IMAGE_TAG=17-0.107.0-ferretdb-2.7.0
FERRETDB_IMAGE_TAG=2.7.0

# Public route
KOMODO_DOMAIN=komodo.logid.xyz
KOMODO_HOST=https://komodo.logid.xyz
KOMODO_TITLE=Reputo Komodo
TRAEFIK_ACME_EMAIL=info@reputo.org
TRAEFIK_LOG_LEVEL=INFO
CF_DNS_API_TOKEN=CHANGE_ME_FROM_PASSWORD_MANAGER

# Host paths to include in the VM backup policy.
TRAEFIK_CERTS_PATH=/etc/komodo/traefik/certs
COMPOSE_KOMODO_DATA_PATH=/etc/komodo/core/data
COMPOSE_KOMODO_BACKUPS_PATH=/etc/komodo/core/backups

# Database credentials for the FerretDB Postgres backend.
KOMODO_DATABASE_USERNAME=komodo
KOMODO_DATABASE_PASSWORD=CHANGE_ME_FROM_PASSWORD_MANAGER

# Runtime
TZ=Europe/Vienna
KOMODO_PERIPHERY_PUBLIC_KEY=file:/config/keys/periphery.pub
KOMODO_PASSKEY=CHANGE_ME_FROM_PASSWORD_MANAGER
KOMODO_LOCAL_AUTH=false
KOMODO_FIRST_SERVER_NAME=komodo-core
KOMODO_DISABLE_CONFIRM_DIALOG=false
KOMODO_DISABLE_INIT_RESOURCES=false
KOMODO_WEBHOOK_SECRET=CHANGE_ME_FROM_PASSWORD_MANAGER
KOMODO_JWT_SECRET=CHANGE_ME_FROM_PASSWORD_MANAGER
KOMODO_JWT_TTL=1-day
KOMODO_CLI_MAX_BACKUPS=30
KOMODO_MONITORING_INTERVAL=15-sec
KOMODO_RESOURCE_POLL_INTERVAL=1-hr

# User onboarding. The first login is the initial admin; later users stay
# disabled until an admin enables them.
KOMODO_DISABLE_USER_REGISTRATION=false
KOMODO_ENABLE_NEW_USERS=false
KOMODO_DISABLE_NON_ADMIN_CREATE=true
KOMODO_TRANSPARENT_MODE=false

# GitHub OAuth login.
# GitHub OAuth app:
#   Homepage URL: https://komodo.logid.xyz
#   Authorization callback URL: https://komodo.logid.xyz/auth/github/callback
KOMODO_GITHUB_OAUTH_ENABLED=true
KOMODO_GITHUB_OAUTH_ID=CHANGE_ME_GITHUB_OAUTH_CLIENT_ID
KOMODO_GITHUB_OAUTH_SECRET=CHANGE_ME_FROM_PASSWORD_MANAGER

# Generic OIDC remains disabled because GitHub auth uses Komodo's GitHub OAuth
# callback above.
KOMODO_OIDC_ENABLED=false

# Self-Periphery outbound connection to Core.
PERIPHERY_CORE_ADDRESS=ws://core:9120
PERIPHERY_CONNECT_AS=komodo-core
PERIPHERY_CORE_PUBLIC_KEYS=file:/config/keys/core.pub
PERIPHERY_PASSKEYS=${KOMODO_PASSKEY}
PERIPHERY_ROOT_DIRECTORY=/etc/komodo
PERIPHERY_DISABLE_TERMINALS=false
PERIPHERY_DISABLE_CONTAINER_TERMINALS=false
PERIPHERY_INCLUDE_DISK_MOUNTS=/etc/hostname
