{
  "name": "@reputo/ui",
  "version": "0.1.1",
  "description": "Next.js dashboard for the Reputo platform.",
  "keywords": [
    "nextjs",
    "react",
    "ui",
    "dashboard",
    "reputo"
  ],
  "license": "GPL-3.0-only",
  "author": {
    "name": "Behzad Rabiei",
    "url": "https://github.com/Behzad-rabiei"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/reputo-org/reputo.git",
    "directory": "apps/ui"
  },
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "build": "next build --turbopack",
    "build:deps": "pnpm --filter @reputo/algorithm-validator --filter @reputo/reputation-algorithms run build",
    "clean": "rm -rf coverage dist docs node_modules tsconfig.tsbuildinfo",
    "check": "biome check",
    "lint": "biome lint",
    "format": "biome format --write",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "test:cov": "vitest --coverage",
    "dev": "pnpm run build:deps && concurrently --names deps,app --prefix name --kill-others-on-fail \"pnpm run dev:deps\" \"pnpm run dev:app\"",
    "dev:app": "next dev --turbopack --hostname 0.0.0.0 --port 4000",
    "dev:deps": "pnpm --filter @reputo/algorithm-validator --filter @reputo/reputation-algorithms --parallel run dev",
    "start": "next start"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@radix-ui/react-accordion": "^1.2.14",
    "@radix-ui/react-alert-dialog": "^1.1.17",
    "@radix-ui/react-aspect-ratio": "^1.1.10",
    "@radix-ui/react-avatar": "^1.2.0",
    "@radix-ui/react-checkbox": "^1.3.5",
    "@radix-ui/react-collapsible": "^1.1.14",
    "@radix-ui/react-context-menu": "^2.3.1",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@radix-ui/react-hover-card": "^1.1.17",
    "@radix-ui/react-label": "^2.1.10",
    "@radix-ui/react-menubar": "^1.1.18",
    "@radix-ui/react-navigation-menu": "^1.2.16",
    "@radix-ui/react-popover": "^1.1.17",
    "@radix-ui/react-progress": "^1.1.10",
    "@radix-ui/react-radio-group": "^1.4.1",
    "@radix-ui/react-scroll-area": "^1.2.12",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-separator": "^1.1.10",
    "@radix-ui/react-slider": "^1.4.1",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.1",
    "@radix-ui/react-tabs": "^1.1.15",
    "@radix-ui/react-toggle": "^1.1.12",
    "@radix-ui/react-toggle-group": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.10",
    "@reputo/algorithm-validator": "workspace:*",
    "@reputo/reputation-algorithms": "workspace:*",
    "@tailwindcss/typography": "^0.5.20",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-table": "catalog:",
    "axios": "catalog:",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.21.0",
    "next": "15.5.7",
    "react": "19.2.7",
    "react-day-picker": "^9.11.1",
    "react-dom": "19.2.7",
    "react-dropzone": "^14.3.8",
    "react-hook-form": "^7.80.0",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^3.0.6",
    "recharts": "2.15.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "vaul": "^1.1.2",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "catalog:",
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@testing-library/user-event": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "concurrently": "catalog:",
    "jsdom": "catalog:",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
