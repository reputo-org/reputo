{
  "name": "@reputo/workflows",
  "version": "2.0.1",
  "description": "Temporal workflows and workers for the Reputo platform.",
  "keywords": [
    "temporal",
    "workflow",
    "orchestration",
    "reputation",
    "algorithms"
  ],
  "license": "GPL-3.0-only",
  "author": {
    "name": "Behzad Rabiei",
    "url": "https://github.com/Behzad-rabiei"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/reputo-org/reputo.git",
    "directory": "apps/workflows"
  },
  "private": true,
  "type": "module",
  "files": [
    "dist/**"
  ],
  "main": "./dist/workflows/index.js",
  "types": "./dist/workflows/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/workflows/index.d.ts",
      "import": "./dist/workflows/index.js",
      "default": "./dist/workflows/index.js"
    },
    "./shared/constants": {
      "types": "./dist/shared/constants/index.d.ts",
      "import": "./dist/shared/constants/index.js",
      "default": "./dist/shared/constants/index.js"
    }
  },
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "build": "tsc",
    "build:deps": "pnpm --filter @reputo/contracts --filter @reputo/deep-id-api --filter @reputo/deepfunding-portal-api --filter @reputo/onchain-data --filter @reputo/reputation-algorithms --filter @reputo/storage run build",
    "clean": "rm -rf coverage dist docs node_modules tsconfig.tsbuildinfo",
    "check": "pnpm exec biome check",
    "lint": "pnpm exec biome lint",
    "format": "pnpm exec biome format --write",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "test:cov": "vitest --coverage",
    "test:e2e": "vitest run --config vitest.config.e2e.ts",
    "test:e2e:watch": "vitest --config vitest.config.e2e.ts",
    "dev": "pnpm run build:deps && concurrently --names deps,workers --prefix name --kill-others-on-fail \"pnpm run dev:deps\" \"pnpm run dev:app\"",
    "dev:app": "concurrently --names orchestrator,algorithm,onchain-data --prefix name --kill-others-on-fail \"pnpm run dev:orchestrator:app\" \"pnpm run dev:algorithm-typescript:app\" \"pnpm run dev:onchain-data:app\"",
    "dev:deps": "pnpm --filter @reputo/contracts --filter @reputo/deep-id-api --filter @reputo/deepfunding-portal-api --filter @reputo/onchain-data --filter @reputo/reputation-algorithms --filter @reputo/storage --parallel run dev",
    "dev:orchestrator": "pnpm run build:deps && concurrently --names deps,orchestrator --prefix name --kill-others-on-fail \"pnpm run dev:deps\" \"pnpm run dev:orchestrator:app\"",
    "dev:orchestrator:app": "nodemon src/workers/typescript/orchestrator.worker.ts",
    "dev:algorithm-typescript": "pnpm run build:deps && concurrently --names deps,algorithm --prefix name --kill-others-on-fail \"pnpm run dev:deps\" \"pnpm run dev:algorithm-typescript:app\"",
    "dev:algorithm-typescript:app": "nodemon src/workers/typescript/algorithm.worker.ts",
    "dev:onchain-data": "pnpm run build:deps && concurrently --names deps,onchain-data --prefix name --kill-others-on-fail \"pnpm run dev:deps\" \"pnpm run dev:onchain-data:app\"",
    "dev:onchain-data:app": "nodemon src/workers/typescript/onchain-data.worker.ts",
    "start:orchestrator": "node dist/workers/typescript/orchestrator.worker.js",
    "start:algorithm-typescript": "node dist/workers/typescript/algorithm.worker.js",
    "start:onchain-data": "node dist/workers/typescript/onchain-data.worker.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "catalog:",
    "@reputo/contracts": "workspace:*",
    "@reputo/deep-id-api": "workspace:*",
    "@reputo/deepfunding-portal-api": "workspace:*",
    "@reputo/onchain-data": "workspace:*",
    "@reputo/reputation-algorithms": "workspace:*",
    "@reputo/storage": "workspace:*",
    "@temporalio/activity": "catalog:",
    "@temporalio/client": "catalog:",
    "@temporalio/worker": "catalog:",
    "@temporalio/workflow": "catalog:",
    "csv-parse": "^5.6.0",
    "csv-stringify": "^6.5.2",
    "pino": "catalog:",
    "pino-pretty": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@testcontainers/postgresql": "catalog:",
    "@types/node": "catalog:",
    "concurrently": "catalog:",
    "nodemon": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
