# Node Environment
NODE_ENV=development

# Logging
LOG_LEVEL=info

# Temporal Configuration
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_ORCHESTRATOR_TASK_QUEUE=orchestrator-worker
TEMPORAL_ALGORITHM_TYPESCRIPT_TASK_QUEUE=algorithm-typescript-worker
TEMPORAL_ALGORITHM_PYTHON_TASK_QUEUE=algorithm-python-worker
TEMPORAL_ONCHAIN_DATA_TASK_QUEUE=onchain-data-worker

AWS_REGION=us-east-1
STORAGE_BUCKET=reputo-dev
STORAGE_PRESIGN_PUT_TTL=120
STORAGE_PRESIGN_GET_TTL=300
STORAGE_MAX_SIZE_BYTES=52428800
STORAGE_CONTENT_TYPE_ALLOWLIST=text/csv,application/json

# Optional explicit AWS credentials (non-production only; recommended to use LocalStack/MinIO creds here)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

DEEPFUNDING_API_BASE_URL=https://api.deepfunding.xyz
DEEPFUNDING_API_KEY=

# On-chain Data PostgreSQL (TypeScript worker and onchain-data worker only)
ONCHAIN_DATA_POSTGRES_HOST=localhost
ONCHAIN_DATA_POSTGRES_PORT=5432
ONCHAIN_DATA_POSTGRES_USER=reputo_onchain
ONCHAIN_DATA_POSTGRES_PASSWORD=reputo_onchain
ONCHAIN_DATA_POSTGRES_DB_NAME=reputo_onchain

# Alchemy (onchain-data worker only)
ALCHEMY_API_KEY=
BLOCKFROST_API_KEY=
