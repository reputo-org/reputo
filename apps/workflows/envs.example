# Node Environment
NODE_ENV=development

# Logging
LOG_LEVEL=info

# Temporal Configuration
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_ORCHESTRATOR_TASK_QUEUE=orchestrator-worker
TEMPORAL_ALGORITHM_TYPESCRIPT_TASK_QUEUE=algorithm-typescript-worker
TEMPORAL_ALGORITHM_PYTHON_TASK_QUEUE=algorithm-python-worker
TEMPORAL_ONCHAIN_DATA_TASK_QUEUE=onchain-data-worker

AWS_REGION=us-east-1
STORAGE_BUCKET=reputo-dev
STORAGE_PRESIGN_PUT_TTL=120
STORAGE_PRESIGN_GET_TTL=300
STORAGE_MAX_SIZE_BYTES=52428800

# Optional explicit AWS credentials (non-production only; recommended to use LocalStack/MinIO creds here).
# Must be set together or both omitted; production uses IAM role credentials.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# DeepFunding Portal API
DEEPFUNDING_API_BASE_URL=https://api.deepfunding.xyz
DEEPFUNDING_API_KEY=replace-with-real-deepfunding-api-key
# Optional tuning knobs (defaults shown):
# DEEPFUNDING_API_REQUEST_TIMEOUT_MS=45000
# DEEPFUNDING_API_CONCURRENCY=4
# DEEPFUNDING_API_DEFAULT_PAGE_LIMIT=500
# DEEPFUNDING_API_RETRY_MAX_ATTEMPTS=7
# DEEPFUNDING_API_RETRY_BASE_DELAY_MS=500
# DEEPFUNDING_API_RETRY_MAX_DELAY_MS=20000

# On-chain Data PostgreSQL connection URL (consumed by the onchain-data
# worker and the token-value-over-time algorithm).
ONCHAIN_DATABASE_URL=postgresql://reputo_onchain:reputo_onchain@localhost:5432/reputo_onchain

# Alchemy + Blockfrost (required by the onchain-data worker)
ALCHEMY_API_KEY=replace-with-real-alchemy-key
BLOCKFROST_API_KEY=replace-with-real-blockfrost-key
