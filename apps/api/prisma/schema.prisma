// Reputo API application database.
//
// Primary keys are UUID v7 strings generated by the Prisma client
// (`@default(uuid(7))`) so the `pg_uuidv7` extension is not required on the
// PG server.
//
// Convention: model fields are camelCase, DB columns are snake_case via
// `@map` / `@@map`. Enums are native Postgres enums (Prisma default).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Lifecycle states of a snapshot. String values are the canonical wire
/// form across the API/Workflows boundary; see `@reputo/contracts`
/// `SnapshotStatus`.
enum SnapshotStatus {
  queued
  running
  completed
  failed
  cancelled

  @@map("snapshot_status")
}

/// Upstream OAuth provider identifiers. The wire value `deep-id` carries the
/// hyphen used by `@reputo/contracts` `OAuthProvider`; the Prisma enum member
/// is `deep_id` because PG enum labels remain hyphen-free in TS.
enum OAuthProvider {
  deep_id @map("deep-id")

  @@map("oauth_provider")
}

/// Roles in the email-keyed access allowlist (one owner + N admins).
enum AccessRole {
  owner
  admin

  @@map("access_role")
}

model AlgorithmPreset {
  id          String   @id @default(uuid(7))
  key         String
  version     String
  /// Array of `{ key, value }` parameter pairs. Kept as Json to avoid a side
  /// table for free-form algorithm inputs.
  inputs      Json     @default("[]")
  name        String?
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  snapshots Snapshot[]

  @@index([key])
  @@index([version])
  @@index([key, version])
  @@map("algorithm_preset")
}

model Snapshot {
  id                    String         @id @default(uuid(7))
  status                SnapshotStatus @default(queued)
  algorithmPresetId     String         @map("algorithm_preset_id")
  /// Immutable copy of the source AlgorithmPreset captured at snapshot
  /// creation. Stored as Json so it survives later edits/deletes of the
  /// source row. Shape mirrors `@reputo/contracts` `AlgorithmPresetFrozenDto`.
  algorithmPresetFrozen Json           @map("algorithm_preset_frozen")
  /// Temporal workflow coordinates (workflowId, runId, taskQueue,
  /// algorithmTaskQueue). Optional until the orchestrator starts the workflow.
  temporal              Json?
  /// Algorithm execution outputs keyed by output name (e.g. `csv`,
  /// `voting_engagement`).
  outputs               Json?
  /// Error payload populated when execution transitions to `failed`.
  error                 Json?
  startedAt             DateTime?      @map("started_at")
  completedAt           DateTime?      @map("completed_at")
  createdAt             DateTime       @default(now()) @map("created_at")
  updatedAt             DateTime       @updatedAt @map("updated_at")

  // Restrict: forces explicit cleanup of dependent snapshots before deleting
  // the parent preset (see task 05 `deletePresetWithSnapshots` transaction).
  algorithmPreset AlgorithmPreset @relation(fields: [algorithmPresetId], references: [id], onDelete: Restrict)

  @@index([algorithmPresetId])
  // A functional index on (`algorithm_preset_frozen`->>'key',
  // `algorithm_preset_frozen`->>'version') is added by a raw SQL block in
  // the init migration — Prisma does not yet model JSON path indexes.
  @@map("snapshot")
}

model OAuthUser {
  id            String        @id @default(uuid(7))
  provider      OAuthProvider
  sub           String
  aud           String[]      @default([])
  authTime      Int?          @map("auth_time")
  email         String?
  emailVerified Boolean?      @map("email_verified")
  iat           Int?
  iss           String?
  picture       String?
  rat           Int?
  username      String?
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  sessions       AuthSession[]
  invitedEntries AccessAllowlist[] @relation("AccessAllowlistInvitedBy")
  revokedEntries AccessAllowlist[] @relation("AccessAllowlistRevokedBy")

  @@unique([provider, sub])
  @@map("oauth_user")
}

model AuthSession {
  id                     String        @id @default(uuid(7))
  sessionId              String        @unique @map("session_id")
  provider               OAuthProvider
  userId                 String        @map("user_id")
  // Secret material — repository selects must opt-in explicitly. There is no
  // Prisma equivalent of Mongoose `select: false`, so callers control
  // projection per query (see task 06).
  accessTokenCiphertext  String        @map("access_token_ciphertext")
  refreshTokenCiphertext String        @map("refresh_token_ciphertext")
  accessTokenExpiresAt   DateTime      @map("access_token_expires_at")
  refreshTokenExpiresAt  DateTime      @map("refresh_token_expires_at")
  scope                  String[]      @default([])
  state                  String
  codeVerifier           String        @map("code_verifier")
  lastRefreshedAt        DateTime?     @map("last_refreshed_at")
  revokedAt              DateTime?     @map("revoked_at")
  // Mongo TTL is replaced by a scheduled cleanup job (task 06).
  expiresAt              DateTime      @map("expires_at")
  createdAt              DateTime      @default(now()) @map("created_at")
  updatedAt              DateTime      @updatedAt @map("updated_at")

  user OAuthUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
  @@map("auth_session")
}

model OAuthConsentGrant {
  id           String        @id @default(uuid(7))
  provider     OAuthProvider
  source       String
  state        String        @unique
  codeVerifier String        @map("code_verifier")
  // Mongo TTL is replaced by a scheduled cleanup job (task 07).
  expiresAt    DateTime      @map("expires_at")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  @@index([provider, source])
  @@map("oauth_consent_grant")
}

model AccessAllowlist {
  id        String        @id @default(uuid(7))
  provider  OAuthProvider
  // Application stores the email lowercased; the `(provider, email)` unique
  // index therefore acts as a case-insensitive provider+email key.
  email     String
  role      AccessRole
  invitedBy String?       @map("invited_by")
  invitedAt DateTime      @default(now()) @map("invited_at")
  revokedAt DateTime?     @map("revoked_at")
  revokedBy String?       @map("revoked_by")
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  // SetNull: keep the audit row when the inviter/revoker user is removed.
  invitedByUser OAuthUser? @relation("AccessAllowlistInvitedBy", fields: [invitedBy], references: [id], onDelete: SetNull)
  revokedByUser OAuthUser? @relation("AccessAllowlistRevokedBy", fields: [revokedBy], references: [id], onDelete: SetNull)

  @@unique([provider, email])
  @@index([revokedAt])
  @@map("access_allowlist")
}
