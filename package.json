{
    "name": "reputo",
    "version": "1.0.0",
    "description": "",
    "private": true,
    "scripts": {
        "build:packages": "turbo run build --filter=\"./packages/*\"",
        "dev:packages": "pnpm --filter \"./packages/*\" --parallel run dev",
        "dev:apps": "pnpm --filter \"./apps/*\" --parallel run dev:app",
        "dev:internal": "pnpm run build:packages && concurrently --names packages,apps --prefix name --kill-others-on-fail \"pnpm run dev:packages\" \"pnpm run dev:apps\"",
        "dev": "tsx scripts/env/load.ts pnpm run dev:internal",
        "docker:dev": "tsx scripts/env/load.ts docker compose -f docker/compose/dev.yml up --build",
        "start": "pnpm --filter \"./apps/*\" --parallel start",
        "build": "turbo run build",
        "clean": "turbo run clean && rm -rf .turbo node_modules/.cache",
        "check": "turbo run check",
        "lint": "turbo run lint",
        "format": "turbo run format",
        "typecheck": "turbo run typecheck",
        "docs": "turbo run docs",
        "cz": "cz",
        "release": "semantic-release",
        "start:backend": "pnpm --filter @reputo/api dev",
        "start:frontend": "pnpm --filter @reputo/ui dev",
        "start:temporal": "pnpm --filter @reputo/workflows dev",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:cov": "vitest run --coverage",
        "ci:test": "turbo run build --filter=\"./packages/*\" && pnpm run test:cov",
        "docker:build": "sh -c 'test -n \"$1\" || { echo \"usage: pnpm docker:build <api|ui|workflows>\" >&2; exit 1; }; docker buildx build --build-arg APP_NAME=\"$1\" -f \"apps/$1/Dockerfile\" -t \"ghcr.io/reputo-org/reputo/$1:local\" .' --",
        "postinstall": "command -v git >/dev/null 2>&1 && lefthook install || echo 'Git not found, skipping lefthook install'",
        "algorithm:create": "tsx scripts/create-algorithm.ts",
        "algorithm:validate": "tsx scripts/validate-algorithms.ts"
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "@prisma/client",
            "@prisma/engines",
            "better-sqlite3",
            "prisma"
        ]
    },
    "devDependencies": {
        "@biomejs/biome": "catalog:",
        "@commitlint/cli": "catalog:",
        "@commitlint/config-conventional": "catalog:",
        "@semantic-release/commit-analyzer": "catalog:",
        "@semantic-release/github": "catalog:",
        "@semantic-release/release-notes-generator": "catalog:",
        "@types/node": "catalog:",
        "@vitest/coverage-v8": "catalog:",
        "@vitest/ui": "catalog:",
        "concurrently": "catalog:",
        "commitizen": "^4.3.1",
        "cz-conventional-changelog": "^3.3.0",
        "lefthook": "^1.11.16",
        "semantic-release": "catalog:",
        "semantic-release-commits-lint": "catalog:",
        "tsconfig-paths": "catalog:",
        "tsx": "catalog:",
        "turbo": "^2.5.6",
        "typescript": "catalog:",
        "vitest": "catalog:"
    },
    "config": {
        "commitizen": {
            "path": "cz-conventional-changelog"
        }
    },
    "keywords": [],
    "author": "",
    "license": "GPL-3.0-only",
    "packageManager": "pnpm@10.30.3"
}
