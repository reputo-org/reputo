{
  "name": "reputo",
  "version": "1.0.0",
  "description": "Reputo monorepo — Temporal-orchestrated reputation pipeline for the Cardano ecosystem (api, ui, workflows, and supporting packages).",
  "keywords": [
    "monorepo",
    "reputation",
    "temporal",
    "cardano",
    "deepfunding"
  ],
  "license": "GPL-3.0-only",
  "author": {
    "name": "Behzad Rabiei",
    "url": "https://github.com/Behzad-rabiei"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/reputo-org/reputo.git"
  },
  "homepage": "https://github.com/reputo-org/reputo#readme",
  "bugs": {
    "url": "https://github.com/reputo-org/reputo/issues"
  },
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "build": "turbo run build",
    "build:packages": "turbo run build --filter=\"./packages/*\"",
    "clean": "turbo run clean && rm -rf .turbo node_modules/.cache",
    "check": "turbo run check",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "typecheck": "turbo run typecheck",
    "docs": "turbo run docs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "ci:test": "turbo run build --filter=\"./packages/*\" && pnpm run test:cov",
    "dev": "tsx scripts/env/load.ts pnpm run dev:internal",
    "dev:api": "pnpm --filter @reputo/api dev",
    "dev:ui": "pnpm --filter @reputo/ui dev",
    "dev:workflows": "pnpm --filter @reputo/workflows dev",
    "dev:apps": "pnpm --filter \"./apps/*\" --parallel run dev:app",
    "dev:packages": "pnpm --filter \"./packages/*\" --parallel run dev",
    "dev:internal": "pnpm run build:packages && concurrently --names packages,apps --prefix name --kill-others-on-fail \"pnpm run dev:packages\" \"pnpm run dev:apps\"",
    "start": "pnpm --filter \"./apps/*\" --parallel start",
    "docker:up": "tsx scripts/env/load.ts docker compose -f infra/dev/compose.yml --profile apps --profile infra up -d --build",
    "docker:up:infra": "tsx scripts/env/load.ts docker compose -f infra/dev/compose.yml --profile infra up -d",
    "docker:down": "tsx scripts/env/load.ts docker compose -f infra/dev/compose.yml --profile apps --profile infra down",
    "docker:build": "sh -c 'test -n \"$1\" || { echo \"usage: pnpm docker:build <api|ui|workflows>\" >&2; exit 1; }; docker buildx build --build-arg APP_NAME=\"$1\" -f \"apps/$1/Dockerfile\" -t \"ghcr.io/reputo-org/reputo/$1:local\" .' --",
    "db:migrate": "tsx scripts/env/load.ts pnpm --filter @reputo/api typeorm:run",
    "db:migrate:show": "tsx scripts/env/load.ts pnpm --filter @reputo/api typeorm:show",
    "db:migrate:revert": "tsx scripts/env/load.ts pnpm --filter @reputo/api typeorm:revert",
    "db:migrate:generate": "tsx scripts/env/load.ts pnpm --filter @reputo/api typeorm:generate",
    "db:reset": "docker exec -i postgres psql -U reputo_app -d reputo_app -c 'DROP SCHEMA public CASCADE; CREATE SCHEMA public; GRANT ALL ON SCHEMA public TO reputo_app;' && pnpm db:migrate",
    "algorithm:create": "tsx scripts/create-algorithm.ts",
    "algorithm:validate": "tsx scripts/validate-algorithms.ts",
    "cz": "cz",
    "release": "semantic-release",
    "postinstall": "command -v git >/dev/null 2>&1 && lefthook install || echo 'Git not found, skipping lefthook install'"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@commitlint/cli": "catalog:",
    "@commitlint/config-conventional": "catalog:",
    "@semantic-release/commit-analyzer": "catalog:",
    "@semantic-release/exec": "catalog:",
    "@semantic-release/github": "catalog:",
    "@semantic-release/release-notes-generator": "catalog:",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "@vitest/ui": "catalog:",
    "commitizen": "^4.3.1",
    "concurrently": "catalog:",
    "cz-conventional-changelog": "^3.3.0",
    "lefthook": "^1.11.16",
    "semantic-release": "catalog:",
    "semantic-release-commits-lint": "catalog:",
    "tsconfig-paths": "catalog:",
    "tsx": "catalog:",
    "turbo": "^2.5.6",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "better-sqlite3",
      "prisma"
    ],
    "overrides": {
      "fast-xml-parser@^5.0.0": "^5.3.5",
      "protobufjs@^7.0.0": "^7.5.5"
    }
  }
}
